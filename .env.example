# ============================================================
# LogiTrak — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local or any file containing real secrets.
# ============================================================

# ------------------------------------------------------------
# Supabase — use project-specific values per environment
# Find these in: Supabase Dashboard > Project Settings > API
# ------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ⚠️ SERVER SIDE ONLY — never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ------------------------------------------------------------
# Database — Prisma (direct connection to Supabase Postgres)
# Find in: Supabase Dashboard > Project Settings > Database
# ------------------------------------------------------------
DATABASE_URL=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres

# ------------------------------------------------------------
# Auth (NextAuth.js)
# NEXTAUTH_SECRET: generate with `openssl rand -base64 32`
# NEXTAUTH_URL: full URL of your app (no trailing slash)
# ------------------------------------------------------------
NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_URL=http://localhost:3000

# ------------------------------------------------------------
# Stripe — use test keys for dev/staging, live keys for production
# Find in: Stripe Dashboard > Developers > API Keys
# Webhook secret: Stripe Dashboard > Developers > Webhooks
# ------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ------------------------------------------------------------
# App
# ------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ------------------------------------------------------------
# Email (Resend) — used for workspace invitations
# Get an API key at: https://resend.com
# Leave RESEND_API_KEY blank in dev to skip sending; the would-be
# invite link is logged to the server console instead.
# EMAIL_FROM must be a verified sender address on Resend.
# ------------------------------------------------------------
RESEND_API_KEY=
EMAIL_FROM="LogiTrak <invites@yourdomain.tld>"
