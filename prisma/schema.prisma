generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Workspace {
  id                   String                @id @default(cuid())
  name                 String
  slug                 String                @unique
  industryType         IndustryType          @default(film_tv)
  department           String?               // Film/TV department: lighting, camera, sound, grip, art, costume, props, sfx, locations, production, other
  subscriptionTier     SubscriptionTier      @default(starter)
  subscriptionStatus   SubscriptionStatus    @default(trialing)
  stripeCustomerId     String?
  stripeSubscriptionId String?
  trialEndsAt          DateTime?
  maxUsers             Int                   @default(5)
  maxAssets            Int                   @default(500)
  lastSerialNumber     Int                   @default(0)
  lastPrinterType      String?
  lastLabelSize        String?
  lastLabelDesign      String?
  printerIp            String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  activityEvents       ActivityEvent[]
  checkEvents          CheckEvent[]
  damageReports        DamageReport[]
  equipment            Equipment[]
  equipmentCategories  EquipmentCategory[]
  equipmentProducts    EquipmentProduct[]
  projectSets          ProjectSet[]
  projects             Project[]
  repairLogs           RepairLog[]
  setSnapshots         SetSnapshot[]
  setPhotos            SetPhoto[]
  setLightingLayouts   SetLightingLayout[]
  onLocations          OnLocation[]
  studios              Studio[]
  invitations          WorkspaceInvitation[]
  members              WorkspaceUser[]
  labelBatches         LabelBatch[]
  crossHireEvents      CrossHireEvent[]
  hireCustomers        HireCustomer[]

  @@map("workspaces")
}

model LabelBatch {
  id               String   @id @default(cuid())
  workspaceId      String
  serialStart      Int
  serialEnd        Int
  quantity         Int
  design              String   // minimal | standard | full
  codeType            String   // qr | barcode
  labelType           String   // blank | assigned
  printerType         String   // stickermule | brother_ql | custom_csv
  labelSize           String
  status              String   @default("pending") // pending | complete | cancelled
  fileUrl             String?
  stickerMuleOrderUrl String?
  createdById         String?
  createdAt           DateTime @default(now())
  workspace        Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt])
  @@map("label_batches")
}

model UserProfile {
  id                   String                @id
  email                String                @unique
  displayName          String?
  avatarUrl            String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  department           String?
  fullName             String?
  nickname             String?
  subDepartment        String?
  activityEvents       ActivityEvent[]
  checkEvents          CheckEvent[]
  damageReports        DamageReport[]
  repairLogs           RepairLog[]
  setSnapshots         SetSnapshot[]
  setPhotos            SetPhoto[]
  setLightingLayouts   SetLightingLayout[]
  sentInvitations      WorkspaceInvitation[]
  workspaceMemberships WorkspaceUser[]

  @@map("user_profiles")
}

model WorkspaceUser {
  id          String        @id @default(cuid())
  workspaceId String
  userId      String
  role        WorkspaceRole @default(read_only)
  invitedBy   String?
  joinedAt    DateTime?
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  user        UserProfile   @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@map("workspace_users")
}

model WorkspaceInvitation {
  id          String        @id @default(cuid())
  workspaceId String
  email       String
  role        WorkspaceRole @default(operator)
  invitedById String
  token       String        @unique @default(cuid())
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime      @default(now())
  nickname    String?
  invitedBy   UserProfile   @relation(fields: [invitedById], references: [id])
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("workspace_invitations")
}

model EquipmentCategory {
  id          String             @id @default(cuid())
  workspaceId String
  name        String
  groupName   String
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  equipment   Equipment[]
  products    EquipmentProduct[]
  workspace   Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, name])
  @@map("equipment_categories")
}

model Equipment {
  id            String             @id @default(cuid())
  workspaceId   String
  serial        String
  name          String
  categoryId    String?
  productId     String?
  status        EquipmentStatus    @default(available)
  damageStatus  DamageStatus       @default(normal)
  notes         String?
  assetValue    Decimal?           @db.Decimal(10, 2)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  parentId      String?
  checkEvents   CheckEvent[]
  damageReports DamageReport[]
  category      EquipmentCategory? @relation(fields: [categoryId], references: [id])
  product       EquipmentProduct?  @relation(fields: [productId], references: [id])
  parent        Equipment?         @relation("EquipmentKits", fields: [parentId], references: [id])
  children      Equipment[]        @relation("EquipmentKits")
  workspace     Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  repairLogs      RepairLog[]
  crossHireItems  CrossHireItem[]

  @@unique([workspaceId, serial])
  @@index([workspaceId, status])
  @@index([workspaceId, damageStatus])
  @@index([workspaceId, categoryId])
  @@index([workspaceId, productId])
  @@map("equipment")
}

/// Shared product catalog per workspace. Growing library of canonical product
/// definitions (name, category, description) used to quickly add equipment
/// without retyping and to keep naming consistent.
model EquipmentProduct {
  id            String             @id @default(cuid())
  workspaceId   String
  name          String             // Canonical display name, e.g. "Arri SkyPanel S60-C"
  searchKey     String             // Lowercase, stripped name used for dedupe + search
  categoryId    String?
  description            String?
  defaultDailyHireRate   Decimal? @db.Decimal(10, 2)
  defaultWeeklyHireRate  Decimal? @db.Decimal(10, 2)
  createdAt              DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  equipment     Equipment[]
  category      EquipmentCategory? @relation(fields: [categoryId], references: [id])
  workspace     Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  rateHistory   EquipmentProductRateHistory[]

  @@unique([workspaceId, searchKey])
  @@index([workspaceId, name])
  @@map("equipment_products")
}

/// Append-only audit trail of rate changes for an EquipmentProduct. Written
/// whenever the user saves a rental rate (manually from the rates page, or
/// via the "save as default" prompt during a cross-hire).
model EquipmentProductRateHistory {
  id            String           @id @default(cuid())
  productId     String
  dailyRate     Decimal          @db.Decimal(10, 2)
  weeklyRate    Decimal?         @db.Decimal(10, 2)
  source        String           // "manual" | "cross_hire"
  sourceEventId String?          // CrossHireEvent id when source = "cross_hire"
  recordedById  String?
  recordedAt    DateTime         @default(now())
  product       EquipmentProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, recordedAt])
  @@map("equipment_product_rate_history")
}

model Studio {
  id          String       @id @default(cuid())
  workspaceId String
  name        String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  displayId   String?
  checkEvents CheckEvent[]
  projects    Project[]
  stages      Stage[]
  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, name])
  @@map("studios")
}

model Stage {
  id          String       @id @default(cuid())
  workspaceId String
  studioId    String
  name        String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  checkEvents CheckEvent[]
  projectSets ProjectSet[]
  sets        Set[]
  studio      Studio       @relation(fields: [studioId], references: [id], onDelete: Cascade)

  @@unique([studioId, name])
  @@map("stages")
}

model Set {
  id            String       @id @default(cuid())
  workspaceId   String
  // Exactly one of stageId / onLocationId is set.
  stageId       String?
  onLocationId  String?
  name          String
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  description   String?
  checkEvents   CheckEvent[]
  projectSets   ProjectSet[]
  stage         Stage?       @relation(fields: [stageId], references: [id], onDelete: Cascade)
  onLocation    OnLocation?  @relation(fields: [onLocationId], references: [id], onDelete: Cascade)

  @@unique([stageId, name])
  @@unique([onLocationId, name])
  @@index([workspaceId])
  @@map("sets")
}

// On-location venues (outside a studio). Scoped to a single Project so
// that a given shoot has its own set of "on location" entries. Once a
// project has used a location, it appears in the dropdown for reuse on
// other sets within THAT project.
model OnLocation {
  id          String       @id @default(cuid())
  workspaceId String
  projectId   String
  name        String
  description String?
  address     String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  projectSets ProjectSet[]
  sets        Set[]
  checkEvents CheckEvent[]

  @@unique([projectId, name])
  @@index([workspaceId])
  @@index([projectId])
  @@map("on_locations")
}

model CheckEvent {
  id                       String         @id @default(cuid())
  workspaceId              String
  equipmentId              String
  userId                   String
  eventType                CheckEventType
  productionName           String?
  studioId                 String?
  stageId                  String?
  setId                    String?
  onLocationId             String?
  positionType             PositionType?
  positionDescription      String?
  createdAt                DateTime       @default(now())
  exactLocationDescription String?
  equipment                Equipment      @relation(fields: [equipmentId], references: [id])
  set                      Set?           @relation(fields: [setId], references: [id])
  stage                    Stage?         @relation(fields: [stageId], references: [id])
  studio                   Studio?        @relation(fields: [studioId], references: [id])
  onLocation               OnLocation?    @relation(fields: [onLocationId], references: [id])
  user                     UserProfile    @relation(fields: [userId], references: [id])
  workspace                Workspace      @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId, createdAt(sort: Desc)])
  @@index([equipmentId, createdAt(sort: Desc)])
  @@index([workspaceId, productionName, eventType])
  @@index([onLocationId])
  @@map("check_events")
}

model SetSnapshot {
  id            String      @id @default(cuid())
  workspaceId   String
  name          String
  studioId      String?
  stageId       String?
  setId         String?
  createdById   String
  equipmentList Json
  summary       Json
  createdAt     DateTime    @default(now())
  createdBy     UserProfile @relation(fields: [createdById], references: [id])
  workspace     Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("set_snapshots")
}

model ActivityEvent {
  id          String      @id @default(cuid())
  workspaceId String
  actorId     String
  eventType   String
  description String
  entityType  String
  entityId    String
  createdAt   DateTime    @default(now())
  actor       UserProfile @relation(fields: [actorId], references: [id])
  workspace   Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt(sort: Desc)])
  @@index([entityType, entityId])
  @@map("activity_events")
}

model Project {
  id            String        @id @default(cuid())
  workspaceId   String
  name          String
  industryType  IndustryType  @default(film_tv)
  status        ProjectStatus @default(active)
  startDate     DateTime?
  description   String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  studioId      String?
  eventLocation String?
  projectSets   ProjectSet[]
  onLocations   OnLocation[]
  studio        Studio?       @relation(fields: [studioId], references: [id])
  workspace     Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, status])
  @@map("projects")
}

model ProjectSet {
  id           String      @id @default(dbgenerated("(gen_random_uuid())::text"))
  workspaceId  String
  projectId    String
  setId        String
  // Exactly one of stageId / onLocationId is set.
  stageId      String?
  onLocationId String?
  notes        String?
  createdAt    DateTime    @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime    @default(now()) @updatedAt @db.Timestamptz(6)
  project      Project     @relation(fields: [projectId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "project_sets_projectid_fkey")
  set          Set         @relation(fields: [setId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "project_sets_setid_fkey")
  stage        Stage?      @relation(fields: [stageId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "project_sets_stageid_fkey")
  onLocation   OnLocation? @relation(fields: [onLocationId], references: [id], onDelete: Cascade)
  workspace    Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "project_sets_workspaceid_fkey")

  photos       SetPhoto[]
  layouts      SetLightingLayout[]

  @@unique([projectId, setId], map: "project_sets_projectid_setid_key")
  @@index([workspaceId, projectId], map: "project_sets_workspaceid_projectid_idx")
  @@index([projectId, onLocationId])
  @@map("project_sets")
}

model SetPhoto {
  id            String      @id @default(cuid())
  workspaceId   String
  projectSetId  String
  uploadedById  String
  storagePath   String      // Supabase storage path: set-photos/<workspaceId>/<projectSetId>/<uuid>.<ext>
  filename      String
  mimeType      String
  sizeBytes     Int
  caption       String?
  sortOrder     Int         @default(0)
  createdAt     DateTime    @default(now())
  projectSet    ProjectSet  @relation(fields: [projectSetId], references: [id], onDelete: Cascade)
  uploadedBy    UserProfile @relation(fields: [uploadedById], references: [id])
  workspace     Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([projectSetId, sortOrder])
  @@index([workspaceId])
  @@map("set_photos")
}

model SetLightingLayout {
  id            String      @id @default(cuid())
  workspaceId   String
  projectSetId  String
  uploadedById  String
  storagePath   String      // Supabase storage path: set-layouts/<workspaceId>/<projectSetId>/<uuid>.<ext>
  filename      String
  mimeType      String      // application/pdf, image/png, image/jpeg, etc.
  sizeBytes     Int
  title         String?     // user-provided title (e.g. "Final rig, Day 3")
  description   String?
  sortOrder     Int         @default(0)
  createdAt     DateTime    @default(now())
  projectSet    ProjectSet  @relation(fields: [projectSetId], references: [id], onDelete: Cascade)
  uploadedBy    UserProfile @relation(fields: [uploadedById], references: [id])
  workspace     Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([projectSetId, sortOrder])
  @@index([workspaceId])
  @@map("set_lighting_layouts")
}

model DamageReport {
  id             String      @id @default(cuid())
  workspaceId    String
  equipmentId    String
  reporterId     String
  description    String
  damageLocation String?  // where on set the damage was noticed
  itemLocation    String?  // location on the physical item (e.g. front lens, left handle)
  reportedAt     DateTime    @default(now())
  createdAt      DateTime    @default(now())
  equipment      Equipment   @relation(fields: [equipmentId], references: [id])
  reporter       UserProfile @relation(fields: [reporterId], references: [id])
  workspace      Workspace   @relation(fields: [workspaceId], references: [id])
  repairLogs     RepairLog[]

  @@index([workspaceId, reportedAt(sort: Desc)])
  @@map("damage_reports")
}

model RepairLog {
  id             String        @id @default(cuid())
  workspaceId    String
  equipmentId    String
  damageReportId String?
  repairerId     String?
  repairedByName String
  repairLocation String?
  description    String
  repairedAt     DateTime      @default(now())
  createdAt      DateTime      @default(now())
  damageReport   DamageReport? @relation(fields: [damageReportId], references: [id])
  equipment      Equipment     @relation(fields: [equipmentId], references: [id])
  repairer       UserProfile?  @relation(fields: [repairerId], references: [id])
  workspace      Workspace     @relation(fields: [workspaceId], references: [id])

  @@map("repair_logs")
}

enum SubscriptionTier {
  starter
  professional
  enterprise
}

enum SubscriptionStatus {
  trialing
  active
  past_due
  canceled
}

enum IndustryType {
  film_tv
  events
}

enum WorkspaceRole {
  owner
  admin
  manager
  operator
  read_only
}

enum EquipmentStatus {
  available
  checked_out  // legacy — new records use issued
  issued
  damaged
  under_repair
  repaired
  lost
  retired
  cross_hired
}

enum DamageStatus {
  normal
  damaged
  under_repair
  repaired
}

enum CheckEventType {
  check_out
  check_in
}

enum ProjectStatus {
  active
  wrapped
  archived
}

enum PositionType {
  on_set
  rigged_to_outside_of_set
  inside_prop_make
  in_prop_dressing
}

model HireCustomer {
  id              String           @id @default(cuid())
  workspaceId     String
  productionName  String
  vatNumber       String?
  contactName     String?
  contactEmail    String?
  contactPhone    String?
  addressLine1    String?
  addressLine2    String?
  city            String?
  county          String?
  postcode        String?
  country         String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  workspace       Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  crossHireEvents CrossHireEvent[]

  @@index([workspaceId])
  @@map("hire_customers")
}

model CrossHireEvent {
  id             String               @id @default(cuid())
  workspaceId    String
  hireCustomerId String
  termsOfHire    String
  termValue      Int?                 // Manual duration when no end date — number paired with termUnit
  termUnit       String?              // "days" | "weeks" | "months" — paired with termValue
  totalDays      Int?                 // Computed total days used for rate calculations
  startDate      DateTime
  endDate        DateTime?
  notes          String?
  status         CrossHireEventStatus @default(active)
  createdById    String
  invoiceNumber  String?
  returnedAt     DateTime?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  workspace      Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  hireCustomer   HireCustomer         @relation(fields: [hireCustomerId], references: [id])
  equipmentItems CrossHireItem[]

  @@index([workspaceId, status])
  @@map("cross_hire_events")
}

model CrossHireItem {
  id               String         @id @default(cuid())
  crossHireEventId String
  equipmentId      String
  dailyRate        Decimal        @db.Decimal(10, 2)
  weeklyRate       Decimal?       @db.Decimal(10, 2)
  quantity         Int            @default(1)
  notes            String?
  returnedAt       DateTime?
  crossHireEvent   CrossHireEvent @relation(fields: [crossHireEventId], references: [id], onDelete: Cascade)
  equipment        Equipment      @relation(fields: [equipmentId], references: [id])

  @@map("cross_hire_items")
}

enum CrossHireEventStatus {
  active
  returned
  cancelled
}
