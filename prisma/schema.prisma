generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum SubscriptionTier {
  starter
  professional
  enterprise
}

enum SubscriptionStatus {
  trialing
  active
  past_due
  canceled
}

enum IndustryType {
  film_tv
  events
}

enum WorkspaceRole {
  owner
  admin
  manager
  operator
  read_only
}

enum EquipmentStatus {
  available
  checked_out
  retired
}

enum DamageStatus {
  normal
  damaged
  under_repair
  repaired
}

enum CheckEventType {
  check_out
  check_in
}

enum PositionType {
  on_set
  rigged
  in_props
  in_dressing
}

model Workspace {
  id                   String             @id @default(cuid())
  name                 String
  slug                 String             @unique
  industryType         IndustryType       @default(film_tv)
  subscriptionTier     SubscriptionTier   @default(starter)
  subscriptionStatus   SubscriptionStatus @default(trialing)
  stripeCustomerId     String?
  stripeSubscriptionId String?
  trialEndsAt          DateTime?
  maxUsers             Int                @default(5)
  maxAssets            Int                @default(500)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  members             WorkspaceUser[]
  invitations         WorkspaceInvitation[]
  equipment           Equipment[]
  studios             Studio[]
  equipmentCategories EquipmentCategory[]
  checkEvents         CheckEvent[]
  damageReports       DamageReport[]
  repairLogs          RepairLog[]

  @@map("workspaces")
}

model UserProfile {
  id          String   @id // matches auth.users.id from Supabase
  email       String   @unique
  displayName String?
  avatarUrl   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspaceMemberships WorkspaceUser[]
  sentInvitations      WorkspaceInvitation[]
  checkEvents          CheckEvent[]
  damageReports        DamageReport[]
  repairLogs           RepairLog[]

  @@map("user_profiles")
}

model WorkspaceUser {
  id          String        @id @default(cuid())
  workspaceId String
  userId      String
  role        WorkspaceRole @default(read_only)
  invitedBy   String?
  joinedAt    DateTime?
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  workspace Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@map("workspace_users")
}

model WorkspaceInvitation {
  id          String        @id @default(cuid())
  workspaceId String
  email       String
  role        WorkspaceRole @default(operator)
  invitedById String
  token       String        @unique @default(cuid())
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime      @default(now())

  workspace Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  invitedBy UserProfile @relation(fields: [invitedById], references: [id])

  @@map("workspace_invitations")
}

model EquipmentCategory {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  groupName   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  equipment Equipment[]

  @@unique([workspaceId, name])
  @@map("equipment_categories")
}

model Equipment {
  id           String          @id @default(cuid())
  workspaceId  String
  serial       String
  name         String
  categoryId   String?
  status       EquipmentStatus @default(available)
  damageStatus DamageStatus    @default(normal)
  notes        String?
  assetValue   Decimal?        @db.Decimal(10, 2)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  workspace     Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  category      EquipmentCategory? @relation(fields: [categoryId], references: [id])
  checkEvents   CheckEvent[]
  damageReports DamageReport[]
  repairLogs    RepairLog[]

  @@unique([workspaceId, serial])
  @@map("equipment")
}

model Studio {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  stages      Stage[]
  checkEvents CheckEvent[]

  @@unique([workspaceId, name])
  @@map("studios")
}

model Stage {
  id          String   @id @default(cuid())
  workspaceId String
  studioId    String
  name        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  studio      Studio       @relation(fields: [studioId], references: [id], onDelete: Cascade)
  sets        Set[]
  checkEvents CheckEvent[]

  @@unique([studioId, name])
  @@map("stages")
}

model Set {
  id          String   @id @default(cuid())
  workspaceId String
  stageId     String
  name        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  stage       Stage        @relation(fields: [stageId], references: [id], onDelete: Cascade)
  checkEvents CheckEvent[]

  @@unique([stageId, name])
  @@map("sets")
}

model CheckEvent {
  id                  String         @id @default(cuid())
  workspaceId         String
  equipmentId         String
  userId              String
  eventType           CheckEventType
  productionName      String?
  studioId            String?
  stageId             String?
  setId               String?
  positionType        PositionType?
  positionDescription String?
  createdAt           DateTime       @default(now())

  workspace Workspace   @relation(fields: [workspaceId], references: [id])
  equipment Equipment   @relation(fields: [equipmentId], references: [id])
  user      UserProfile @relation(fields: [userId], references: [id])
  studio    Studio?     @relation(fields: [studioId], references: [id])
  stage     Stage?      @relation(fields: [stageId], references: [id])
  set       Set?        @relation(fields: [setId], references: [id])

  @@map("check_events")
}

model DamageReport {
  id             String   @id @default(cuid())
  workspaceId    String
  equipmentId    String
  reporterId     String
  description    String
  damageLocation String?
  reportedAt     DateTime @default(now())
  createdAt      DateTime @default(now())

  workspace  Workspace    @relation(fields: [workspaceId], references: [id])
  equipment  Equipment    @relation(fields: [equipmentId], references: [id])
  reporter   UserProfile  @relation(fields: [reporterId], references: [id])
  repairLogs RepairLog[]

  @@map("damage_reports")
}

model RepairLog {
  id             String   @id @default(cuid())
  workspaceId    String
  equipmentId    String
  damageReportId String?
  repairerId     String?
  repairedByName String
  repairLocation String?
  description    String
  repairedAt     DateTime @default(now())
  createdAt      DateTime @default(now())

  workspace    Workspace     @relation(fields: [workspaceId], references: [id])
  equipment    Equipment     @relation(fields: [equipmentId], references: [id])
  damageReport DamageReport? @relation(fields: [damageReportId], references: [id])
  repairer     UserProfile?  @relation(fields: [repairerId], references: [id])

  @@map("repair_logs")
}
